class Solution {
    public int minSubArrayLen(int target, int[] nums) {
        int sum=0,l=0,minl=Integer.MAX_VALUE;
        for(int r=0;r<nums.length;r++){
            sum+=nums[r];
            while(sum>=target){
                if(minl>(r-l)+1){
                    minl=(r-l)+1;
                }
                sum-=nums[l];
                l++;
            }
        }
        return minl==Integer.MAX_VALUE ? 0:minl;
    }
}
